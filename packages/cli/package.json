{
  "name": "@relay/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Relay CLI — manage MCP servers from the command line",
  "bin": {
    "relay": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p='dist/index.js';const c=fs.readFileSync(p,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c)};fs.chmodSync(p,0o755)\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
